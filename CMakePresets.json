{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "native"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CUDA_FLAGS_DEBUG": "-g -lineinfo -O0"
      }
    },
    {
      "name": "remote-debug",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/remote-debug",
      "cacheVariables": {
        "CMAKE_CUDA_COMPILER": "/usr/local/cuda/bin/nvcc",
        "CMAKE_C_FLAGS": "-D__REMOTE__",
        "CMAKE_CUDA_FLAGS": "-D__REMOTE__"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CUDA_FLAGS_RELEASE": "-O2 -lineinfo"
      }
    }
  ]
}
